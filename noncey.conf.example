[general]
domain              = nonces.yourdomain.com
nonce_lifetime_h    = 2
archive_retention_d = 30
flask_port          = 5000
# generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
secret_key          = CHANGE_ME

[mysql]
host      = localhost
user      = postfix_ro
password  = CHANGE_ME
database  = postfix

[tls]
cert = /etc/ssl/noncey/fullchain.pem
key  = /etc/ssl/noncey/privkey.pem

[smtp]
# Used for transactional emails (e.g. account deletion confirmation).
# Leave host empty to disable outgoing email.
host     = localhost
port     = 25
# tls: no | starttls | ssl
tls      = no
username =
password =
from     = noncey@nonces.yourdomain.com

[paths]
install_dir  = /opt/noncey/daemon
db_path      = /opt/noncey/daemon/var/noncey.db
archive_path = /opt/noncey/daemon/var/archive
